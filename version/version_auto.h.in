#ifndef __VERSION_AUTO_H__
#define __VERSION_AUTO_H__

#define SDK_VERSION_MAJOR        @SDK_VERSION_MAJOR@
#define SDK_VERSION_MINOR        @SDK_VERSION_MINOR@
#define SDK_VERSION_PATCH        @SDK_VERSION_PATCH@

#define SDK_VERSION_STR          "V@SDK_VERSION_MAJOR@.@SDK_VERSION_MINOR@.@SDK_VERSION_PATCH@-@SDK_BUILD_TYPE@+@BUILD_DATE@.@GIT_SHORT_HASH@"
#define SDK_VERSION_CODE         @VERSION_CODE@

#define SDK_GIT_HASH             "@GIT_HASH@"
#define SDK_GIT_SHORT_HASH       "@GIT_SHORT_HASH@"
#define SDK_GIT_BRANCH           "@GIT_BRANCH@"

#define SDK_BUILD_DATE           "@BUILD_DATE@"
#define SDK_BUILD_TIME           "@BUILD_TIME@"
#define SDK_COMPILER_VERSION     "@CMAKE_C_COMPILER_VERSION@"
#define SDK_HW_PLATFORM          "@SDK_HW_PLATFORM@"
#define SDK_BUILD_TYPE           "@SDK_BUILD_TYPE@"

#endif
